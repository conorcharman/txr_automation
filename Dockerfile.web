# =============================================================================
# Dockerfile.web — Multi-stage build for React SPA + Nginx
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1: builder — Node 20, build the Vite/React app
# -----------------------------------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package manifests first for better layer caching.
# The web/ directory may be partially scaffolded; COPY tolerates missing files
# when using a glob, but we use explicit paths for clarity.
COPY web/package*.json ./

# Install dependencies (ci for reproducible builds; falls back gracefully if
# package-lock.json is absent during early scaffolding).
RUN npm ci 2>/dev/null || npm install

# Copy the rest of the frontend source
COPY web/ ./

# Build the production bundle
RUN npm run build

# -----------------------------------------------------------------------------
# Stage 2: final — Nginx serves the built SPA
# -----------------------------------------------------------------------------
FROM nginx:alpine AS final

# Remove default Nginx static assets
RUN rm -rf /usr/share/nginx/html/*

# Copy built assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# Inject custom Nginx config (handles SPA routing + API proxy + WebSockets)
COPY nginx.conf /etc/nginx/nginx.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
