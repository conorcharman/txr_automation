# Example Local Environment Configuration
# Copy this file to local.yaml and customize for your environment
# local.yaml is in .gitignore and will not be committed

# Path configuration
paths:
  input_folder: "C:/Users/YOUR_USERNAME/Documents/data/input"
  output_folder: "C:/Users/YOUR_USERNAME/Documents/data/output"
  reference_data: "data/reference"

# Logging configuration
logging:
  level: DEBUG
  log_file: "logs/txr_automation.log"

# Processing options
processing:
  enable_validation: true
  save_intermediate_files: true
