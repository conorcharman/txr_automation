# TXR Automation — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Generate SECRET_KEY with:
#   openssl rand -hex 32

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=txr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=txr_automation

# Async SQLAlchemy connection URL (used by api + worker)
DATABASE_URL=postgresql+asyncpg://txr:changeme@db/txr_automation

# ---------------------------------------------------------------------------
# Redis (Celery broker & WebSocket pub/sub)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# File paths (inside container)
# ---------------------------------------------------------------------------
UPLOAD_DIR=/app/data/uploads
FIRDS_DB_PATH=/app/data/firds_cache.db
GLEIF_DB_PATH=/app/data/gleif_cache.db

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Replace with the output of: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# Frontend (Vite build-time variable — only used during `npm run build`)
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# Figaro DB
DAILY_RECON_SERVER=10.62.136.8,1433
DAILY_RECON_DATABASE=FIGARO
DAILY_RECON_UID=app_user
DAILY_RECON_PWD=changeme
DAILY_RECON_DRIVER=ODBC Driver 17 for SQL Server
DAILY_RECON_TRUST_CERT=yes
